#!/bin/bash
echo "==============================================="
echo "CORRIGINDO Gradle para AGP 8.2.2 + Kotlin 1.9.10"
echo "==============================================="

# 1️⃣ Atualiza Gradle Wrapper para 8.2
echo "[1/5] Atualizando Gradle Wrapper para 8.2..."
./gradlew wrapper --gradle-version 8.2 --distribution-type all || true

# 2️⃣ Força o distributionUrl no gradle-wrapper.properties
echo "[2/5] Corrigindo gradle-wrapper.properties..."
sed -i 's|distributionUrl=.*|distributionUrl=https\://services.gradle.org/distributions/gradle-8.2-all.zip|' gradle/wrapper/gradle-wrapper.properties

# 3️⃣ Limpa caches antigos
echo "[3/5] Limpando caches antigos..."
rm -rf ~/.gradle/caches/
./gradlew clean || true

# 4️⃣ Build de teste local
echo "[4/5] Tentando build debug local..."
./gradlew assembleDebug --no-daemon

# 5️⃣ Commit e push para GitHub
echo "[5/5] Commitando alterações do wrapper e push..."
git add gradle/wrapper/gradle-wrapper.properties gradlew gradlew.bat
git commit -m "Atualiza Gradle Wrapper para 8.2 compatível AGP 8.2.2"
git push origin main

echo "==============================================="
echo "Gradle Wrapper atualizado para 8.2. Agora o GitHub Actions deve usar a versão correta."
echo "==============================================="
